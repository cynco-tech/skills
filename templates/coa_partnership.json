  "additional_schedules": {
    "profit_appropriation": {
      "description": "Required for partnerships. Shows how net profit is distributed among partners.",
      "structure": [
        "Net Profit for the year",
        "Less: Partners' Salary (Partner A: RM___, Partner B: RM___)",
        "Less: Interest on Capital (Partner A: RM___, Partner B: RM___)",
        "= Divisible Profit",
        "Shared per profit-sharing ratio (Partner A: __%, Partner B: __%)"
      ]
    },
    "partners_current_account": {
      "description": "Running balance per partner showing their entitlement and withdrawals.",
      "columns": ["Opening Balance", "Add: Share of Profit", "Add: Salary", "Add: Interest on Capital", "Less: Drawings", "Closing Balance"]
    }
  }
